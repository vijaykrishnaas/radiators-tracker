# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# MongoDB connection. Local dev uses the docker container `radiator-mongo`.
# For production, point this at your own cluster (e.g. a MongoDB Atlas URI).
MONGO_URI=mongodb://localhost:27017
PORT=5000

# Auth — generate a long, random secret for production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=24h

# Client admin seeded for the migrated tenant (change the password).
ADMIN_USER_ID=admin
ADMIN_PASSWORD=replace-me

# Platform super-admin (manages all clients). Seeded on boot if absent.
SUPERADMIN_USER_ID=superadmin
SUPERADMIN_PASSWORD=replace-me
SUPERADMIN_NAME=Platform Admin
